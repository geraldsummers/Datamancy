{
  "uid": "alpha-run-index",
  "title": "Alpha Run Index",
  "tags": ["trading", "alpha", "research", "runs", "index"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Persisted Runs",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM alpha_research_runs WHERE $__timeFilter(generated_at)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Accepted Runs",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM alpha_research_runs WHERE $__timeFilter(generated_at) AND validation_accepted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latest Run Time",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM MAX(generated_at)) AS value FROM alpha_research_runs WHERE $__timeFilter(generated_at)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latest Accepted Run Time",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM MAX(generated_at)) AS value FROM alpha_research_runs WHERE $__timeFilter(generated_at) AND validation_accepted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Latest Runs",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT generated_at, run_id, strategy_family, mode, exchange, validation_accepted, backtest_accepted, forward_accepted, trend_score_mode, signal_bar_minutes, forward_hours, rebalance_cadence_hours, factor_lookback_days, selection_quantile, residualization_beta_mode, residualization_market_proxy_mode, tail_weighting_mode, funding_overlay_mode, exit_overlay_mode, backtest_edge_after_cost_bps, forward_edge_after_cost_bps, backtest_trade_count, forward_trade_count, grafana_path, CONCAT('https://grafana.datamancy.net', grafana_path) AS chart_url FROM alpha_research_runs WHERE $__timeFilter(generated_at) ORDER BY generated_at DESC LIMIT 500"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 4 },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      }
    }
  ]
}
