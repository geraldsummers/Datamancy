          "rawSql": "SELECT COALESCE(EXTRACT(EPOCH FROM (NOW() - MAX(finalized_through))), 0) AS value FROM feature_materialization_state WHERE bar_size_minutes = 1440 AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}')"
