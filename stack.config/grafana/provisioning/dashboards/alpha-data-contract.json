{
  "uid": "alpha-data-contract",
  "title": "Alpha Data Contract",
  "tags": [
    "trading",
    "alpha",
    "data",
    "contract"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "contract_exchange",
        "type": "query",
        "label": "Exchange",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "query": "SELECT '__all' AS __text, '__all' AS __value UNION SELECT exchange AS __text, exchange AS __value FROM (SELECT DISTINCT exchange FROM raw_sync_state UNION SELECT DISTINCT exchange FROM feature_materialization_state UNION SELECT DISTINCT exchange FROM feature_coverage_state UNION SELECT DISTINCT exchange FROM execution_context_1m UNION SELECT DISTINCT exchange FROM alpha_signal_panel_1d) exchanges ORDER BY 1",
        "definition": "SELECT '__all' AS __text, '__all' AS __value UNION SELECT exchange AS __text, exchange AS __value FROM (SELECT DISTINCT exchange FROM raw_sync_state UNION SELECT DISTINCT exchange FROM feature_materialization_state UNION SELECT DISTINCT exchange FROM feature_coverage_state UNION SELECT DISTINCT exchange FROM execution_context_1m UNION SELECT DISTINCT exchange FROM alpha_signal_panel_1d) exchanges ORDER BY 1",
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "__all",
          "value": "__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Raw Candle Symbols",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM raw_sync_state WHERE channel = 'candle_1m' AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "green", "value": 96 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
