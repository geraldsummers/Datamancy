          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(EXTRACT(EPOCH FROM (NOW() - MAX(latest_raw_time))), 0) AS value FROM raw_sync_state WHERE channel = 'candle_1m' AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
