      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Weakest Daily Signal Coverage",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT symbol, ROUND((coverage_ratio * 100)::numeric, 2) AS coverage_pct, ROUND((finalized_ratio * 100)::numeric, 2) AS finalized_pct, observed_bars, expected_bars, latest_feature_time, finalized_through, last_computed_at FROM feature_coverage_state WHERE bar_size_minutes = 1440 AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}') ORDER BY coverage_ratio ASC, finalized_ratio ASC, symbol ASC LIMIT 25"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Raw Sync Lag By Channel",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT channel, symbol, ROUND(EXTRACT(EPOCH FROM (NOW() - latest_raw_time))::numeric, 0) AS raw_lag_s, row_count, latest_raw_time, last_observed_at, last_persisted_at FROM raw_sync_state WHERE ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}') ORDER BY raw_lag_s DESC NULLS LAST, channel ASC, symbol ASC LIMIT 40"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Daily Signal Materialization State",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT symbol, feature_rows, latest_feature_time, finalized_through, ROUND(EXTRACT(EPOCH FROM (NOW() - last_materialized_at))::numeric, 0) AS materializer_lag_s, last_materialized_at FROM feature_materialization_state WHERE bar_size_minutes = 1440 AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}') ORDER BY latest_feature_time DESC NULLS LAST, symbol ASC LIMIT 30"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Raw Rows By Channel",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT channel, SUM(row_count) AS rows_total FROM raw_sync_state WHERE ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}') GROUP BY 1 ORDER BY 2 DESC"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "barRadius": 0,
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Daily Signal Writes",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time_bucket('1 day', source_updated_at) AS \"time\", COUNT(*) FILTER (WHERE is_provisional) AS \"Provisional\", COUNT(*) FILTER (WHERE is_finalized) AS \"Finalized\" FROM alpha_signal_panel_1d WHERE $__timeFilter(source_updated_at) AND ('${contract_exchange}' = '__all' OR exchange = '${contract_exchange}') GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
